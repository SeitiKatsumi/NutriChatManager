DATABASE_URL=postgres://user:password@host:5432/database
SESSION_SECRET=change_me

DIRECTUS_URL=https://nutrichatbot.app.11mind.com.br
DIRECTUS_TOKEN=your_directus_admin_token

OPENAI_API_KEY=sk-proj-...

STRIPE_SECRET_KEY=sk_test_or_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLIC_KEY=pk_test_or_live_...

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+15551234567

# Public Node/Express application origin used by Twilio request signature validation.
# Do not use the Directus URL here.
TWILIO_WEBHOOK_BASE_URL=https://your-public-domain.example
TWILIO_VALIDATE_WEBHOOK_SIGNATURE=true

# Optional: use a Messaging Service instead of TWILIO_WHATSAPP_FROM.
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required only when a new inbound WhatsApp contact is not yet registered as a patient.
TWILIO_DEFAULT_NUTRITIONIST_ID=

# Optional for outbound scheduled messages outside the 24h WhatsApp service window.
# The approved Twilio Content template should accept {{1}} as the message text.
TWILIO_USE_CONTENT_TEMPLATES=false
TWILIO_WHATSAPP_TEMPLATE_CONTENT_SID=
